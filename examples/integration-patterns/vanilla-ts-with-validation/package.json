{
  "name": "social-embed-example-vanilla-ts-with-validation",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 4316",
    "build": "vite build && tsc --noEmit",
    "check": "pnpm run type-check",
    "format:check": "biome format . --check",
    "lint": "biome lint .",
    "preview": "vite preview",
    "start": "vite",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "type-check": "oxlint --type-aware --type-check -A all --tsconfig tsconfig.json src",
    "type-check:tsc": "tsc --noEmit",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run check && pnpm run test && pnpm run build",
    "test:unit": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@social-embed/lib": "^0.1.0-next.11",
    "@social-embed/wc": "^0.1.0-next.13",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.2",
    "oxlint": "^1.57.0",
    "playwright": "^1.58.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
