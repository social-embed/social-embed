{
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @social-embed/lib build && pnpm --filter @social-embed/wc build",
    "clean": "pnpm run --recursive clean",
    "distclean": "pnpm run --recursive distclean",
    "format": "pnpm run --recursive format",
    "format:check": "biome format . --check",
    "lint": "biome lint .",
    "check": "pnpm run --recursive check",
    "type-check": "pnpm run --recursive type-check",
    "type-check:tsc": "pnpm run --recursive type-check:tsc",
    "build:watch": "pnpm run --recursive build:watch",
    "test": "pnpm run --recursive test",
    "test:watch": "pnpm run --recursive test:watch",
    "ncu": "pnpm run ncu-local -u; pnpm run --recursive ncu",
    "ncu-local": "ncu",
    "update": "pnpm run --recursive update",
    "update:all": "ncu -u; pnpm --recursive run 'ncu' -u",
    "docs": "pnpm run --recursive docs",
    "docs:gen:watch": "pnpm run --recursive docs:gen:watch",
    "docs:serve": "pnpm run --recursive docs:serve",
    "examples:sync-deps": "pnpm tsx scripts/update-example-deps.ts",
    "verify:integration-patterns": "pnpm exec biome check . && pnpm check && pnpm --filter @social-embed/lib test && pnpm --filter @social-embed/wc test && pnpm --filter \"./examples/integration-patterns/*\" test && pnpm --filter @social-embed/site test && pnpm --filter \"./examples/integration-patterns/*\" build && pnpm --filter @social-embed/site build && pnpm tsx scripts/smoke-example-previews.ts",
    "serve": "pnpm run --recursive serve",
    "deduplicate": "npx --yes yarn-deduplicate yarn.lock"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "cross-env": "^10.1.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "tsx": "^4.21.0"
  }
}
