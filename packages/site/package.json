{
  "name": "@social-embed/site",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "type-check": "astro sync && tsc --noEmit -p tsconfig.typecheck.json && echo '[site] NOTE: .astro templates unchecked under TS7 - astro check returns at TS 7.1 (pnpm type-check:astro)'",
    "type-check:astro": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "ncu": "ncu",
    "update": "ncu",
    "lint": "biome lint .",
    "biome": "biome",
    "format": "pnpm run biome check . --write; pnpm run biome format . --write",
    "prebuild": "pnpm docs:oembed",
    "prestart": "pnpm docs:oembed",
    "prepare": "pnpm --filter @social-embed/wc build; mkdir -p public/js && cp ../wc/dist/OEmbedElement.js public/js/o-embed.bundled.js",
    "docs:oembed": "[ ! -f ../wc/dist/OEmbedElement.js ] && pnpm --filter @social-embed/wc build; mkdir -p public/js && cp ../wc/dist/OEmbedElement.js public/js/o-embed.bundled.js"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.4",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@pagefind/default-ui": "^1.5.2",
    "@social-embed/lib": "workspace:*",
    "@social-embed/wc": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.4",
    "@types/hast": "^3.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro-expressive-code": "^0.44.0",
    "es-module-lexer": "^2.3.1",
    "github-slugger": "^2.0.0",
    "glob": "^13.0.6",
    "happy-dom": "^20.10.6",
    "magic-string": "^0.30.21",
    "pagefind": "^1.5.2",
    "satteri": "^0.9.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
