---
/**
 * Pure Astro homepage - NO Starlight components or classes.
 * Uses Font component for fonts, core components for header.
 */
import "../tailwind.css";
import { Font } from "astro:assets";
// Core header components
import CoreHeaderLayout from "../components/core/CoreHeaderLayout.astro";
import PurePackageNav from "../components/core/PurePackageNav.astro";
import PureSiteTitle from "../components/core/PureSiteTitle.astro";
import PureSocialIcons from "../components/core/PureSocialIcons.astro";
import PureThemeSelect from "../components/core/PureThemeSelect.astro";
import GitPullLogo from "../components/GitPullLogo.astro";
import { LibPlayground } from "../components/lib-playground/LibPlayground";
import { MiniPlayground } from "../components/playground/MiniPlayground";
import { ReadonlyCode } from "../components/playground/ReadonlyCode";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="One tag to rule all embeds. Store URLs, not embed code." />
    <title>social-embed</title>
    <link rel="icon" href="/favicon.ico" />

    <!-- Load fonts via Astro experimental fonts API -->
    <Font cssVariable="--font-ibm-plex-sans" preload />
    <Font cssVariable="--font-ibm-plex-mono" preload />

    <!-- Theme script (inline to prevent flash) -->
    <script is:inline>
      (() => {
        let stored = null;
        try {
          stored = localStorage.getItem('starlight-theme');
        } catch {
          // localStorage unavailable (private browsing, security restrictions)
        }
        // Preference: what the user selected (light/auto/dark)
        const preference = stored === 'light' ? 'light'
                         : stored === 'dark' ? 'dark'
                         : 'auto';
        // Resolved: actual theme to apply (light/dark)
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = preference === 'auto'
                       ? (prefersDark ? 'dark' : 'light')
                       : preference;
        document.documentElement.dataset.themePreference = preference;
        document.documentElement.dataset.theme = resolved;
      })();
    </script>
  </head>
  <body class="min-h-screen bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 font-sans">
    <!-- Header using core components -->
    <header class="sticky top-0 z-50" style="height: var(--nav-height); background-color: var(--nav-bg); border-bottom: 1px solid var(--nav-border); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
      <CoreHeaderLayout>
        <PureSiteTitle slot="logo" />
        <PurePackageNav slot="package-nav" />
        <PureSocialIcons slot="social" />
        <PureThemeSelect slot="theme" />
      </CoreHeaderLayout>
    </header>

    <main class="px-4 md:px-8 py-6 max-w-7xl mx-auto">
      <!-- Hero -->
      <div class="text-center mb-10">
        <h1 class="text-3xl font-bold mb-2">social-embed</h1>
        <p class="text-lg text-slate-700 dark:text-slate-300 mb-4 max-w-2xl mx-auto">
          One tag to rule all embeds. Store URLs, not embed code.
        </p>
        <div class="flex justify-center gap-3 mb-8">
          <a href="/getting-started" class="inline-flex items-center gap-1 bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
            Get started <span aria-hidden="true">&rarr;</span>
          </a>
          <a href="/how-it-works" class="inline-flex items-center gap-1 text-indigo-600 dark:text-indigo-400 px-4 py-2 rounded-lg text-sm font-medium border border-indigo-200 dark:border-indigo-800 hover:bg-indigo-50 dark:hover:bg-indigo-950 transition-colors">
            How it works
          </a>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap justify-center gap-6 mb-12 text-sm text-slate-600 dark:text-slate-400">
        <span>7 built-in providers</span>
        <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
        <span>~2 kB lib · ~10 kB component</span>
        <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
        <span>Zero dependencies (lib)</span>
        <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
        <span>Framework-agnostic</span>
        <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
        <span>No backend required</span>
        <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
        <span>SSR ready</span>
        <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">|</span>
        <span>CLS guidance</span>
      </div>

      <!-- Before / After -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-2">Before — stored in your database</p>
          <ReadonlyCode
            client:only="react"
            code={`<iframe width="560" height="315"
  src="https://www.youtube.com/embed/Bd8_vO5zrjo"
  frameborder="0"
  allow="accelerometer; autoplay;
    clipboard-write; encrypted-media;
    gyroscope; picture-in-picture"
  allowfullscreen></iframe>`}
          />
        </div>
        <div class="flex flex-col">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-2">After — <code class="text-indigo-600 dark:text-indigo-400">&lt;o-embed&gt;</code></p>
          <MiniPlayground client:only="react" className="h-full" codeHeight="50px" iframeHeight="350px" initialViewMode="snippet" />
        </div>
      </div>

      <!-- Use cases -->
      <div class="max-w-4xl mx-auto mb-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/integration-patterns#rich-text-editors" class="group block rounded-lg border border-slate-200 dark:border-slate-700 p-4 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
            <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">Rich text editors</p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">One TipTap/ProseMirror node for every provider.</p>
          </a>
          <a href="/integration-patterns#markdown-and-mdx" class="group block rounded-lg border border-slate-200 dark:border-slate-700 p-4 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
            <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">Markdown & MDX</p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Survives parsing, renders in the browser.</p>
          </a>
          <a href="/integration-patterns#database--cms-content" class="group block rounded-lg border border-slate-200 dark:border-slate-700 p-4 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
            <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">CMS & databases</p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Update the library, not your data.</p>
          </a>
          <a href="/getting-started#have-30-seconds" class="group block rounded-lg border border-slate-200 dark:border-slate-700 p-4 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
            <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">Sandboxes</p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">One CDN script, zero configuration.</p>
          </a>
        </div>
      </div>

      <!-- Two packages -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Web Component -->
        <section id="playground" class="flex flex-col scroll-mt-20">
          <div class="mb-3">
            <div class="flex items-baseline justify-between gap-2">
              <h2 class="text-lg font-semibold">Web Component</h2>
              <a href="/wc/" class="inline-flex items-center gap-1 text-indigo-600 dark:text-indigo-400 hover:underline text-sm font-medium">
                Get started <span aria-hidden="true">→</span>
              </a>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm">
              Drop <code class="bg-slate-100 dark:bg-slate-800 px-1 rounded text-xs">&lt;o-embed&gt;</code> anywhere.
            </p>
          </div>
          <div class="flex-1">
            <MiniPlayground client:only="react" className="h-full" codeHeight="275px" iframeHeight="425px" />
          </div>
        </section>

        <!-- Library -->
        <section class="flex flex-col">
          <div class="mb-3">
            <div class="flex items-baseline justify-between gap-2">
              <h2 class="text-lg font-semibold">Library</h2>
              <a href="/lib/" class="inline-flex items-center gap-1 text-indigo-600 dark:text-indigo-400 hover:underline text-sm font-medium">
                Get started <span aria-hidden="true">→</span>
              </a>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm">
              Extract IDs, generate embed URLs, detect providers.
            </p>
          </div>
          <div class="flex-1">
            <LibPlayground client:only="react" mode="mini" />
          </div>
        </section>
      </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-4 px-4 flex flex-col items-center gap-2 text-xs text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-700">
      <div>
        © 2021-{new Date().getFullYear()} <a href="https://tony.sh" class="hover:underline">Tony Narlock</a>
      </div>
      <GitPullLogo />
    </footer>
  </body>
</html>
