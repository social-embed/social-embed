---
import {
  type IntegrationPatternExample,
  integrationPatternExamples,
} from "@examples/integration-patterns/manifest";
import { DemoLayout } from "../../../components/demo/DemoLayout";
import IntegrationPatternExampleDetail from "../../../components/demo/IntegrationPatternExampleDetail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return integrationPatternExamples.map(
    (example: IntegrationPatternExample) => ({
      params: { id: example.id },
      props: { example },
    }),
  );
}

const { example } = Astro.props;
---

<BaseLayout
  title={`${example.title} Example`}
  description={example.problemSolved}
  hideFooter
>
  <div class="demo-container">
    <DemoLayout
      currentPath={`/demo/integration-patterns/${example.id}`}
      client:only="react"
    >
      <IntegrationPatternExampleDetail
        basePath="/demo/integration-patterns"
        example={example}
      />
    </DemoLayout>
  </div>
</BaseLayout>

<style>
  .demo-container {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }
</style>
